{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OpenArchives Download Snapshot Manifest",
  "type": "object",
  "required": [
    "snapshot_id",
    "collection_slug",
    "stage",
    "created_at",
    "scraper_version",
    "storage_backend",
    "storage_prefix",
    "document_count",
    "pdf_file_count",
    "total_bytes",
    "notes"
  ],
  "properties": {
    "snapshot_id": {
      "type": "string"
    },
    "collection_slug": {
      "type": "string"
    },
    "stage": {
      "type": "string",
      "enum": [
        "bulk_run_scraper",
        "snapshot_publish"
      ]
    },
    "created_at": {
      "type": "string"
    },
    "scraper_version": {
      "type": "string"
    },
    "agent_run_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "source_run_dir": {
      "type": [
        "string",
        "null"
      ]
    },
    "storage_backend": {
      "type": "string",
      "enum": [
        "local",
        "s3",
        "hybrid"
      ]
    },
    "storage_prefix": {
      "type": "string"
    },
    "sha256_manifest_path": {
      "type": [
        "string",
        "null"
      ]
    },
    "download_log_path": {
      "type": [
        "string",
        "null"
      ]
    },
    "telemetry_snapshot_path": {
      "type": [
        "string",
        "null"
      ]
    },
    "document_count": {
      "type": "integer",
      "minimum": 0
    },
    "pdf_file_count": {
      "type": "integer",
      "minimum": 0
    },
    "total_bytes": {
      "type": "integer",
      "minimum": 0
    },
    "failed_items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "item_id",
          "reason"
        ],
        "properties": {
          "item_id": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "notes": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "additionalProperties": false
}
